{
  "name": "music-video-generator",
  "version": "2.0.0",
  "description": "AI Music Video Generator",
  "author": "AI Music Video Generator",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && tsc -p tsconfig.electron.json && electron .",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "check": "npm run typecheck && npm run build",
    "test:e2e-storyboard": "node scripts/run_python.js scripts/e2e_storyboard_smoke.py",
    "test:lyrics": "node scripts/run_python.js -m unittest scripts/test_lyrics_parser.py",
    "test:cloud-storyboard": "node scripts/run_python.js -m unittest scripts/test_cloud_storyboard.py",
    "test:director": "node scripts/run_python.js -m unittest scripts/test_director.py",
    "test:video-resume": "node scripts/run_python.js -m unittest scripts/test_video_task_resume.py",
    "test:export-policy": "tsc -p tsconfig.electron.json && node scripts/test_export_policy.js",
    "test:backend-port": "tsc -p tsconfig.electron.json && node scripts/test_backend_port.js",
    "test:e2e-export": "node scripts/run_python.js scripts/e2e_export_mv.py",
    "backend:exe": "node scripts/run_python.js scripts/build_backend_exe.py",
    "pack:full": "npm run backend:exe && npm run build && electron-builder --dir",
    "dist:full": "npm run backend:exe && npm run build && electron-builder",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "backend": "node scripts/run_python.js backend/main.py"
  },
  "build": {
    "appId": "com.musicvideo.generator",
    "productName": "AI Music Video Generator",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "!node_modules/**/.env",
      "!node_modules/**/.env.*"
    ],
    "extraResources": [
      {
        "from": "backend_dist",
        "to": "backend-exe",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/ffmpeg.exe",
      "node_modules/@ffmpeg-installer/win32-x64/ffmpeg.exe"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@ant-design/icons": "^5.2.6",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "antd": "^5.12.0",
    "axios": "^1.6.2",
    "ffmpeg-static": "^5.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.2",
    "vite": "^5.0.6",
    "vite-plugin-electron": "^0.15.4",
    "wait-on": "^7.2.0"
  }
}
